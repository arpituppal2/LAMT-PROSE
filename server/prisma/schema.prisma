generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  initials  String
  mathExp   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  problems      Problem[]
  feedbacks     Feedback[]
  testsAuthored Test[]        @relation("TestAuthor")
  testComments  TestComment[]
}
model Problem {
  id           String   @id
  authorId     String
  latex        String   @db.Text
  solution     String   @db.Text @default("")
  answer       String   @default("")
  notes        String   @db.Text @default("")
  topics       String[]
  quality      String
  stage        String   @default("Idea")
  examType    String  @default("Numerical Answer")
  solveCount   Int      @default(0)
  unresolved   Int      @default(0)
  endorsements Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  feedbacks Feedback[]
  tests     Test[]     @relation("ProblemToTest")
  @@index([authorId])
  @@index([stage])
  @@index([solveCount])
  @@index([endorsements])
}
model Feedback {
  id            String   @id @default(uuid())
  problemId     String
  userId        String
  answer        String
  feedback      String   @db.Text
  authorReply   String?  @db.Text
  resolved      Boolean  @default(false)
  needsReview   Boolean  @default(false)
  isEndorsement Boolean  @default(false)
  timeSpent     Int?
  createdAt     DateTime @default(now())
  problem  Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([problemId])
  @@index([userId])
  @@index([needsReview])
}
model Test {
  id           String   @id @default(uuid())
  competition  String
  name         String
  description  String?
  version      String
  authorId     String?
  templateType String?
  slots        Json?
  createdAt    DateTime @default(now())
  author       User?         @relation("TestAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  problems     Problem[]     @relation("ProblemToTest")
  comments     TestComment[]
  @@index([authorId])
}
model TestComment {
  id        String   @id @default(uuid())
  testId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([testId])
  @@index([userId])
}
