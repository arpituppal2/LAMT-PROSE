generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  initials   String
  mathExp    String
  isAdmin    Boolean  @default(false)
  disabled   Boolean  @default(false)
  pageAccess Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  problems          Problem[]
  feedbacks         Feedback[]
  testsAuthored     Test[]           @relation("TestAuthor")
  testComments      TestComment[]
  problemComments   ProblemComment[]
  notifications     Notification[]
  testsolveSessions TestsolveSession[]
}
model Problem {
  id           String   @id
  authorId     String
  latex        String   @db.Text
  solution     String   @db.Text @default("")
  answer       String   @default("")
  notes        String   @db.Text @default("")
  topics       String[]
  quality      String
  stage        String   @default("Idea")
  examType    String  @default("Numerical Answer")
  solveCount   Int      @default(0)
  unresolved   Int      @default(0)
  endorsements Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author          User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  feedbacks       Feedback[]
  tests           Test[]           @relation("ProblemToTest")
  notifications   Notification[]
  comments        ProblemComment[]
  @@index([authorId])
  @@index([stage])
  @@index([solveCount])
  @@index([endorsements])
}
model Feedback {
  id            String   @id @default(uuid())
  problemId     String
  userId        String
  answer        String
  feedback      String   @db.Text
  authorReply   String?  @db.Text
  resolved      Boolean  @default(false)
  needsReview   Boolean  @default(false)
  isEndorsement Boolean  @default(false)
  timeSpent     Int?
  createdAt     DateTime @default(now())
  problem  Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([problemId])
  @@index([userId])
  @@index([needsReview])
}
model Notification {
  id        String   @id @default(uuid())
  userId    String
  problemId String?
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([problemId])
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rounds      TournamentRound[]
  tests       Test[]
}

model TournamentRound {
  id           String   @id @default(uuid())
  tournamentId String
  name         String
  roundType    String   @default("Individual") // "Individual" | "Team"
  createdAt    DateTime @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  @@index([tournamentId])
}

model Test {
  id               String   @id @default(uuid())
  competition      String
  name             String
  description      String?
  roundType        String?  // "Individual" | "Team"
  roundName        String?  // free-text or from TournamentRound
  numSets          Int      @default(1)
  questionsPerSet  Int      @default(10)
  estimationSets   Int      @default(0)
  examTopics       String[]
  tournamentId     String?
  authorId         String?
  slots            Json?
  // ── Testsolving fields ──────────────────────────────────────────────
  isLocked          Boolean  @default(false)
  lockedAt          DateTime?
  timeLimit         Int?
  testsolveStatus   String   @default("none") // "none" | "active" | "paused"
  testsolvePassword String?
  testsolveVersion  Int      @default(1)
  // ───────────────────────────────────────────────────────────────────
  createdAt        DateTime @default(now())
  author           User?         @relation("TestAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  tournament       Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  problems         Problem[]     @relation("ProblemToTest")
  comments         TestComment[]
  testsolveSessions TestsolveSession[]
  @@index([authorId])
  @@index([tournamentId])
}
model TestComment {
  id        String   @id @default(uuid())
  testId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([testId])
  @@index([userId])
}
model ProblemComment {
  id        String   @id @default(uuid())
  problemId String
  userId    String
  parentId  String?
  body      String   @db.Text
  likes     String[] @default([])
  createdAt DateTime @default(now())
  problem  Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ProblemComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ProblemComment[] @relation("CommentReplies")
  @@index([problemId])
  @@index([userId])
  @@index([parentId])
}

// ════════════════════════════════════════════════════════════
// TESTSOLVING MODELS
// ════════════════════════════════════════════════════════════

model TestsolveSession {
  id               String    @id @default(uuid())
  testId           String
  userId           String
  examVersion      Int       @default(1)
  submittedAt      DateTime?
  createdAt        DateTime  @default(now())
  problemResponses TestsolveProblemResponse[]
  overall          TestsolveOverall?
  test             Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([testId])
  @@index([userId])
}

model TestsolveProblemResponse {
  id          String  @id @default(uuid())
  sessionId   String
  problemId   String
  slotIndex   Int
  answer      String  @db.Text @default("")
  workArea    String  @db.Text @default("")
  comment     String  @db.Text @default("")
  timeMinutes Int?
  session     TestsolveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@index([sessionId])
}

model TestsolveOverall {
  id              String @id @default(uuid())
  sessionId       String @unique
  generalComments String @db.Text @default("")
  difficultyNotes String @db.Text @default("")
  techniqueNotes  String @db.Text @default("")
  reworkNotes     String @db.Text @default("")
  finalRating     String @default("needs_work")
  session         TestsolveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
